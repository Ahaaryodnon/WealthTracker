{
  "name": "wealthtracker-1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run lint && npm run build",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "update-data": "tsx scripts/update-data.ts",
    "data:sync": "tsx scripts/data-sync.ts",
    "build:ci": "(npm run data:sync || echo 'Sync failed or skipped; building with committed data.') && npm run build",
    "deploy": "npm run build && npx wrangler pages deploy out --project-name=wealthtracker"
  },
  "dependencies": {
    "convex": "^1.32.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
