# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# scraped supplemental source JSON (optional; generated by npm run scrape-sources)
scripts/data/*.json

# env files (can opt-in for committing if needed)
.env*

# vercel (legacy)
.vercel

# cloudflare
.wrangler

# typescript
*.tsbuildinfo
next-env.d.ts
